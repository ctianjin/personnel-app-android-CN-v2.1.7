<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/header_background"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 返回按钮 -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:padding="8dp"
            android:contentDescription="返回"
            app:tint="@color/text_white" />

        <!-- 标题 -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="人员详情"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:gravity="center"
            android:layout_marginEnd="40dp" />

    </LinearLayout>

    <!-- 滚动内容 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 头像（圆形白色背景） -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_avatar_circle_white">

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_avatar_placeholder"
                    android:contentDescription="头像" />

            </FrameLayout>

            <!-- 基本信息（两列布局） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <!-- 第一行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="姓  名："
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="性别："
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                    <TextView
                        android:id="@+id/tvGender"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                </LinearLayout>

                <!-- 第二行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="出生年月："
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                    <TextView
                        android:id="@+id/tvBirthDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="学历："
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                    <TextView
                        android:id="@+id/tvEducation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                </LinearLayout>

                <!-- 第三行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="工作时间："
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                    <TextView
                        android:id="@+id/tvWorkStartDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="身份："
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                    <TextView
                        android:id="@+id/tvIdentity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                </LinearLayout>

                <!-- 第四行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="入党时间："
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                    <TextView
                        android:id="@+id/tvPoliticalStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="籍贯："
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                    <TextView
                        android:id="@+id/tvAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                </LinearLayout>

                <!-- 第五行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="现任职务："
                        android:textSize="14sp"
                        android:textColor="@color/text_white" />

                    <TextView
                        android:id="@+id/tvPosition"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textColor="@color/text_white"
                        android:maxLines="2"
                        android:ellipsize="end" />

                </LinearLayout>

            </LinearLayout>

            <!-- 个人简历 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="个人简历："
                android:textSize="14sp"
                android:textColor="@color/text_white"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvWorkExperiences"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_box"
                android:padding="12dp"
                android:textSize="13sp"
                android:textColor="@color/text_white"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp" />

            <!-- 家庭成员及重要社会关系 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="家庭成员及重要社会关系："
                android:textSize="14sp"
                android:textColor="@color/text_white"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvFamilyMembers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_box"
                android:padding="12dp"
                android:textSize="13sp"
                android:textColor="@color/text_white"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp" />

            <!-- 个人奖惩 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="个人奖惩："
                android:textSize="14sp"
                android:textColor="@color/text_white"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvAwards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_box"
                android:padding="12dp"
                android:textSize="13sp"
                android:textColor="@color/text_white"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp" />

            <!-- 简要评价 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="简要评价："
                android:textSize="14sp"
                android:textColor="@color/text_white"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvComment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_box"
                android:padding="12dp"
                android:textSize="13sp"
                android:textColor="@color/text_white"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
