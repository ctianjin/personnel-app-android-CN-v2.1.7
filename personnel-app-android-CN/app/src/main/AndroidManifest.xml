<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ==================== 存储权限 ==================== -->
    <!-- Android 12 及以下 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"
        tools:ignore="ScopedStorage" />
    
    <!-- Android 13+ (API 33+) 媒体权限 -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    
    <!-- Android 14+ (API 34+) 照片选择器 -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />

    <!-- ==================== 网络权限 ==================== -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- ==================== 其他权限 ==================== -->
    <!-- 相机权限（用于拍照） -->
    <uses-permission android:name="android.permission.CAMERA"
        android:required="false" />
    
    <!-- 位置权限（可选，用于记录工作地点） -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        android:required="false" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_avatar_placeholder"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_avatar_placeholder"
        android:supportsRtl="true"
        android:theme="@style/Theme.PersonnelApp"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="34">

        <!-- ==================== 主界面（一级菜单） ==================== -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.PersonnelApp.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- ==================== 启动页/导入页 ==================== -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.PersonnelApp.NoActionBar" />
        
        <!-- ==================== 镇府机构列表（二级菜单） ==================== -->
        <activity
            android:name=".ui.InstitutionListActivity"
            android:exported="false"
            android:label="镇府内设机构"
            android:parentActivityName=".ui.MainActivity"
            android:theme="@style/Theme.PersonnelApp" />
        
        <!-- ==================== 村社区列表（二级菜单） ==================== -->
        <activity
            android:name=".ui.VillageListActivity"
            android:exported="false"
            android:label="村（社区）列表"
            android:parentActivityName=".ui.MainActivity"
            android:theme="@style/Theme.PersonnelApp" />
        
        <!-- ==================== 人员列表（三级菜单） ==================== -->
        <activity
            android:name=".ui.PersonnelListActivity"
            android:exported="false"
            android:label="人员列表"
            android:parentActivityName=".ui.VillageListActivity"
            android:theme="@style/Theme.PersonnelApp" />
        
        <!-- ==================== 数据导入（独立界面） ==================== -->
        <activity
            android:name=".ui.ImportActivity"
            android:exported="false"
            android:label="数据导入"
            android:parentActivityName=".ui.MainActivity"
            android:theme="@style/Theme.PersonnelApp" />

        <!-- ==================== 人员详情界面 ==================== -->
        <activity
            android:name=".ui.DetailActivity"
            android:exported="false"
            android:label="@string/title_activity_detail"
            android:parentActivityName=".ui.MainActivity"
            android:theme="@style/Theme.PersonnelApp" />

        <!-- ==================== 新增/编辑人员界面 ==================== -->
        <activity
            android:name=".ui.EditActivity"
            android:exported="false"
            android:label="@string/title_activity_edit"
            android:parentActivityName=".ui.MainActivity"
            android:theme="@style/Theme.PersonnelApp"
            android:windowSoftInputMode="adjustResize" />

        <!-- ==================== 数据同步界面 ==================== -->
        <activity
            android:name=".ui.SyncActivity"
            android:exported="false"
            android:label="@string/title_activity_sync"
            android:parentActivityName=".ui.MainActivity"
            android:theme="@style/Theme.PersonnelApp" />

        <!-- ==================== 设置界面 ==================== -->
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:label="@string/title_activity_settings"
            android:parentActivityName=".ui.MainActivity"
            android:theme="@style/Theme.PersonnelApp" />

        <!-- ==================== 文件提供者 ==================== -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
